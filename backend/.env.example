# Example using zot registry api
REGISTRY_HOST=localhost:5000

# Use https for production
REGISTRY_PROTOCOL=http

# Disk cache for rendered logos and OG cards (keyed on the published version).
# Leave CACHE_DIR empty to disable the cache entirely.
CACHE_DIR=/tmp/tx3-registry-cache
# Positive entry TTL in seconds (default 86400).
CACHE_TTL_SECS=86400
# Negative ("not found") entry TTL in seconds (default 60).
CACHE_NEG_TTL_SECS=60
# Eviction budget in bytes (default 536870912 = 512 MiB).
CACHE_MAX_BYTES=536870912